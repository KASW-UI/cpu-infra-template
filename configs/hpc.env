# HPC general runtime configuration

# OpenBLAS thread control (avoid oversubscription with OpenMP)
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

# Allow perf for non-root
# Set on host: echo -1 > /proc/sys/kernel/perf_event_paranoid

# NUMA awareness
# numactl --cpunodebind=0 --membind=0 ./your_app

# Work dir
WORKSPACE=/workspace
