# PyTorch runtime tuning parameters
# Adjust based on your workload and GPU topology.

# CUDA memory allocator
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# OpenMP thread control
OMP_NUM_THREADS=16

# CUDA launch blocking (enable for precise stack traces)
# CUDA_LAUNCH_BLOCKING=1

# Determinisitic mode (enable for reproducibility)
# CUBLAS_WORKSPACE_CONFIG=:4096:8

# JIT profiling verbosity
# TORCH_CUDA_ARCH_LIST=8.0
