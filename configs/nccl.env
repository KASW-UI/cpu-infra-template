# NCCL runtime configuration
# Source this before running multi-GPU workloads.
# Adjust for your network topology (IB, RoCE, eth).

NCCL_DEBUG=INFO
NCCL_SOCKET_IFNAME=eth0
NCCL_IB_DISABLE=1
NCCL_P2P_DISABLE=0
NCCL_SHM_DISABLE=0

# NVLink / NVSwitch tuning (uncomment for DGX / HGX)
# NCCL_NET_GDR_LEVEL=5
# NCCL_IB_DISABLE=0
# NCCL_IB_GID_INDEX=3
# NCCL_IB_HCA=mlx5

# Debug verbosity (increase for troubleshooting)
# NCCL_DEBUG=WARN
# NCCL_DEBUG_SUBSYS=ALL
